{
  "name": "linkedin-feed-vanisher",
  "version": "1.0.0",
  "description": "Removes the LinkedIn news feed for maximum focus.",
  "scripts": {
    "sync": "node scripts/sync-content-shared.js",
    "clean": "node scripts/clean-packages.js",
    "prefirefox": "npm run sync",
    "firefox": "web-ext run --source-dir=firefox.package",
    "prechrome": "npm run sync",
    "chrome": "web-ext run --source-dir=chrome.package --target chromium",
    "prefirefox:run": "npm run sync",
    "firefox:run": "web-ext run --source-dir=firefox.package --no-reload",
    "prechrome:run": "npm run sync",
    "chrome:run": "web-ext run --source-dir=chrome.package --target chromium --no-reload",
    "prebuild:firefox": "npm run sync",
    "build:firefox": "web-ext build --source-dir=firefox.package --artifacts-dir=firefox_source --filename=linkedin-feed-vanisher-firefox.zip --overwrite-dest",
    "prebuild:chrome": "npm run sync",
    "build:chrome": "web-ext build --source-dir=chrome.package --artifacts-dir=chrome_source --filename=linkedin-feed-vanisher-chrome.zip --overwrite-dest",
    "build:chromium": "npm run build:chrome"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajw170/LinkedIn-Feed-Vanisher.git"
  },
  "author": "Andrew Wood",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ajw170/LinkedIn-Feed-Vanisher/issues"
  },
  "homepage": "https://github.com/ajw170/LinkedIn-Feed-Vanisher#readme",
  "devDependencies": {
    "@types/chrome": "^0.1.24",
    "@types/firefox-webext-browser": "^120.0.4",
    "web-ext": "^10.1.0"
  }
}
